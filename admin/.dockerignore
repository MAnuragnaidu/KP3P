# Dependencies and build output (reinstalled/rebuilt in image)
node_modules/
.next/

# Secrets — never bake into image
.env
.env.local
.env*.local

# Rulebook text cache (regenerated by seed:rulebook-text during build)
medical-doc/IBD_Clinical_Rulebook_Final2.txt

# Local documentation (not needed to run the app)
medical-lit/

# Logs
npm-debug.log*

# Version control
.git/
.gitignore

# Root-level markdown (README, AGENTS.md, etc.)
/*.md

# scripts/ is required at build time (seed:rulebook-text → scripts/seedRulebookText.ts)
